# Solana MCP Server Configuration

# Your Solana private key (base58 encoded) — only needed for write operations
# PRIVATE_KEY=your_base58_private_key_here

# Solana RPC endpoint (defaults to mainnet-beta)
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Log level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# SSE server port (only used with --sse flag)
PORT=3001
