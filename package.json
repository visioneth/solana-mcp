{
  "name": "@visioneth/solana-mcp",
  "version": "0.1.0",
  "description": "A Model Context Protocol server for interacting with the Solana blockchain — wallet ops, SPL tokens, DeFi, NFTs, program interactions, and analytics.",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "bin": {
    "solana-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:sse": "tsx watch src/index.ts --sse",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "@solana/web3.js": "^1.98.0",
    "@solana/spl-token": "^0.4.9",
    "@metaplex-foundation/mpl-token-metadata": "^3.3.0",
    "@metaplex-foundation/umi": "^0.9.2",
    "@metaplex-foundation/umi-bundle-defaults": "^0.9.2",
    "bs58": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/visioneth/solana-mcp.git"
  },
  "keywords": [
    "solana",
    "mcp",
    "model-context-protocol",
    "ai-agent",
    "blockchain",
    "defi",
    "nft",
    "web3"
  ],
  "author": "visioneth"
}
